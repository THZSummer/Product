<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.openapp.application.mapper.ApplicationMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.openapp.application.domain.Application">
        <id column="id" property="id" jdbcType="VARCHAR"/>
        <result column="name" property="name" jdbcType="VARCHAR"/>
        <result column="description" property="description" jdbcType="VARCHAR"/>
        <result column="icon_url" property="iconUrl" jdbcType="VARCHAR"/>
        <result column="type" property="type" jdbcType="VARCHAR" 
                typeHandler="org.apache.ibatis.type.EnumOrdinalTypeHandler"/>
        <result column="status" property="status" jdbcType="VARCHAR" 
                typeHandler="org.apache.ibatis.type.EnumOrdinalTypeHandler"/>
        <result column="owner_id" property="ownerId" jdbcType="VARCHAR"/>
        <result column="owner_type" property="ownerType" jdbcType="VARCHAR"/>
        <result column="callback_url" property="callbackUrl" jdbcType="VARCHAR"/>
        <result column="version" property="version" jdbcType="INTEGER"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="created_by" property="createdBy" jdbcType="VARCHAR"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
        <result column="updated_by" property="updatedBy" jdbcType="VARCHAR"/>
        <result column="deleted_at" property="deletedAt" jdbcType="TIMESTAMP"/>
        <result column="deleted_by" property="deletedBy" jdbcType="VARCHAR"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, name, description, icon_url, type, status, owner_id, owner_type, 
        callback_url, version, created_at, created_by, updated_at, updated_by, 
        deleted_at, deleted_by
    </sql>

    <!-- 基础查询条件（排除软删除） -->
    <sql id="Where_Not_Deleted">
        WHERE deleted_at IS NULL
    </sql>

    <!-- 根据 ID 查询应用 -->
    <select id="findById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM applications
        WHERE id = #{id}
        AND deleted_at IS NULL
    </select>

    <!-- 根据所有者 ID 查询应用列表 -->
    <select id="findByOwnerId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM applications
        WHERE owner_id = #{ownerId}
        AND deleted_at IS NULL
        ORDER BY created_at DESC
    </select>

    <!-- 根据状态查询应用列表 -->
    <select id="findByStatus" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM applications
        WHERE status = #{status}
        AND deleted_at IS NULL
        ORDER BY created_at DESC
    </select>

    <!-- 根据所有者 ID 和状态查询应用列表 -->
    <select id="findByOwnerIdAndStatus" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM applications
        WHERE owner_id = #{ownerId}
        AND status = #{status}
        AND deleted_at IS NULL
        ORDER BY created_at DESC
    </select>

    <!-- 根据所有者 ID 和名称查询应用 -->
    <select id="findByOwnerIdAndName" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM applications
        WHERE owner_id = #{ownerId}
        AND name = #{name}
        AND deleted_at IS NULL
    </select>

    <!-- 检查名称是否已存在（排除指定 ID） -->
    <select id="existsByOwnerIdAndNameExcludeId" resultType="boolean">
        SELECT COUNT(1) > 0
        FROM applications
        WHERE owner_id = #{ownerId}
        AND name = #{name}
        AND id != #{excludeId}
        AND deleted_at IS NULL
    </select>

    <!-- 软删除应用 -->
    <update id="softDelete">
        UPDATE applications
        SET deleted_at = NOW(),
            deleted_by = #{deletedBy},
            updated_at = NOW(),
            updated_by = #{deletedBy}
        WHERE id = #{id}
        AND deleted_at IS NULL
    </update>

    <!-- 恢复已软删除的应用 -->
    <update id="restore">
        UPDATE applications
        SET deleted_at = NULL,
            deleted_by = NULL,
            status = 'draft',
            updated_at = NOW()
        WHERE id = #{id}
        AND deleted_at IS NOT NULL
    </update>

    <!-- 更新应用（包含乐观锁版本控制） -->
    <update id="updateWithVersion">
        UPDATE applications
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="iconUrl != null">icon_url = #{iconUrl},</if>
            <if test="type != null">type = #{type},</if>
            <if test="status != null">status = #{status},</if>
            <if test="ownerId != null">owner_id = #{ownerId},</if>
            <if test="ownerType != null">owner_type = #{ownerType},</if>
            <if test="callbackUrl != null">callback_url = #{callbackUrl},</if>
            updated_at = NOW(),
            updated_by = #{updatedBy},
            version = version + 1
        </set>
        WHERE id = #{id}
        AND version = #{version}
        AND deleted_at IS NULL
    </update>

    <!-- 查询所有应用（包含已删除的，用于管理员） -->
    <select id="findAllWithDeleted" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM applications
        ORDER BY created_at DESC
    </select>

</mapper>
